<?php
/**
 * Central language/bootstrap listener for mopedgarage.
 */
namespace bruno\mopedgarage\event;

use phpbb\auth\auth;
use phpbb\config\config;
use phpbb\controller\helper;
use phpbb\event\data;
use phpbb\event\listener_interface;
use phpbb\language\language;
use phpbb\request\request_interface;
use phpbb\template\template;
use Symfony\Component\EventDispatcher\EventSubscriberInterface;

class listener implements EventSubscriberInterface, listener_interface
{
    protected auth $auth;
    protected template $template;
    protected language $language;
    protected config $config;
    protected request_interface $request;
    protected helper $helper;

    public function __construct(
        auth $auth,
        template $template,
        language $language,
        config $config,
        request_interface $request,
        helper $helper
    ) {
        $this->auth = $auth;
        $this->template = $template;
        $this->language = $language;
        $this->config = $config;
        $this->request = $request;
        $this->helper = $helper;
    }

    public static function getSubscribedEvents(): array
    {
        return [
            'core.user_setup'                           => 'on_user_setup',
            'core.page_header'                          => 'on_page_header',
            'core.viewtopic_modify_post_row'            => 'on_viewtopic_modify_post_row',
            'core.memberlist_view_profile'              => 'on_memberlist_view_profile',
            'core.acp_manage_forums_request_data'       => 'on_acp_context',
            'core.ucp_display_module_before'            => 'on_ucp_context',
        ];
    }

    public function on_user_setup(data $event): void
    {
        $lang_set_ext = $event['lang_set_ext'];
        $lang_set_ext[] = [
            'ext_name' => 'bruno/mopedgarage',
            'lang_set' => 'common',
        ];
        $lang_set_ext[] = [
            'ext_name' => 'bruno/mopedgarage',
            'lang_set' => 'acp_mopedgarage',
        ];
        $lang_set_ext[] = [
            'ext_name' => 'bruno/mopedgarage',
            'lang_set' => 'ucp_mopedgarage',
        ];
        $event['lang_set_ext'] = $lang_set_ext;
    }

    public function on_page_header(): void
    {
        $this->language->add_lang('common', 'bruno/mopedgarage');
        $this->template->assign_vars([
            'MOPEDGARAGE_GALLERY_URL'   => $this->helper->route('bruno_mopedgarage_gallery'),
            'MOPEDGARAGE_LIGHTBOX'      => true,
            'MOPEDGARAGE_ENABLE_GALLERY'=> (bool) ($this->config['mopedgarage_enable_gallery'] ?? 1),
        ]);
    }

    public function on_viewtopic_modify_post_row(data $event): void
    {
        $this->language->add_lang('common', 'bruno/mopedgarage');
        // Template vars are assigned by the data provider; here we only ensure common labels exist.
        $post_row = $event['post_row'];
        $post_row['MOPEDGARAGE_LABEL_OWNER'] = $this->language->lang('MOPEDGARAGE_OWNER');
        $post_row['MOPEDGARAGE_LABEL_YEAR'] = $this->language->lang('MOPEDGARAGE_YEAR');
        $post_row['MOPEDGARAGE_LABEL_COLOR'] = $this->language->lang('MOPEDGARAGE_COLOR');
        $post_row['MOPEDGARAGE_LABEL_DISPLACEMENT'] = $this->language->lang('MOPEDGARAGE_DISPLACEMENT_SHORT');
        $event['post_row'] = $post_row;
    }

    public function on_memberlist_view_profile(): void
    {
        $this->language->add_lang('common', 'bruno/mopedgarage');
    }

    public function on_acp_context(): void
    {
        $this->language->add_lang('acp_mopedgarage', 'bruno/mopedgarage');
    }

    public function on_ucp_context(): void
    {
        $this->language->add_lang(['common', 'ucp_mopedgarage'], 'bruno/mopedgarage');
    }
}
